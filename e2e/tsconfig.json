{
  "ts-node": {
    "transpileOnly": true,
    "files": true
  },
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",
    "lib": ["ES2019"],
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node", "@wdio/globals/types", "@wdio/cucumber-framework"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "test-artifacts"]
}
